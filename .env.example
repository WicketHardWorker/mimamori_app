# ===== Tapo デバイス設定 =====
# TP-Link アカウント（Tapoアプリで使用しているもの）
TAPO_USERNAME=your_tplink_email@example.com
TAPO_PASSWORD=your_tplink_password

# デバイスIPアドレス（ルーターの管理画面で確認）
TAPO_H100_IP=192.168.1.100
TAPO_P110M_IP=192.168.1.101

# ===== LINE Messaging API 設定 =====
# LINE Developers Console で取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
# 通知を送る相手のLINE User ID
LINE_TARGET_USER_ID=your_line_user_id

# ===== アラート設定 =====
# 朝の安否確認時刻（HH:MM形式）
MORNING_CHECK_TIME=08:00
# 不活動アラートの閾値（分）
INACTIVITY_THRESHOLD_MINUTES=180
# ポーリング間隔（秒）
POLLING_INTERVAL_SECONDS=60

# ===== アプリ設定 =====
# Webサーバーのポート
APP_PORT=8000
# データベースファイルパス
DATABASE_URL=sqlite+aiosqlite:///./mimamori.db
# タイムゾーン
TIMEZONE=Asia/Tokyo
